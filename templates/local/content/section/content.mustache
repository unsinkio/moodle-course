    // Lightweight Markdown → HTML converter for assistant messages.
    function simpleMarkdown(text) {
        if (!text) return '';
        // Escape HTML to prevent XSS, then we selectively convert markdown.
        var esc = text.replace(/&/g, '&amp;').replace(/</g, '&lt;').replace(/>/g, '&gt;');

        // Fenced code blocks: ```...```
        esc = esc.replace(/```([\s\S]*?)```/g, function(m, code) {
            return '<pre class="vc-md-pre"><code>' + code.trim() + '</code></pre>';
        });

        // Inline code: `...`
        esc = esc.replace(/`([^`]+)`/g, '<code class="vc-md-code">$1</code>');

        // Bold: **...**
        esc = esc.replace(/\*\*(.+?)\*\*/g, '<strong>$1</strong>');

        // Italic: *...* (bold already converted, so remaining * are italic)
        esc = esc.replace(/\*(.+?)\*/g, '<em>$1</em>');

        // Split into lines for block-level elements.
        var lines = esc.split('\n');
        var html = [];
        var inUl = false, inOl = false;

        for (var i = 0; i < lines.length; i++) {
            var line = lines[i];

            // Skip lines inside <pre> blocks (already handled).
            if (line.indexOf('<pre') !== -1 || line.indexOf('</pre>') !== -1 ||
                line.indexOf('<code>') !== -1 && line.indexOf('</code></pre>') !== -1) {
                if (inUl) { html.push('</ul>'); inUl = false; }
                if (inOl) { html.push('</ol>'); inOl = false; }
                html.push(line);
                continue;
            }

            // Headings: ### / ## / #
            var headingMatch = line.match(/^(#{1,3})\s+(.+)$/);
            if (headingMatch) {
                if (inUl) { html.push('</ul>'); inUl = false; }
                if (inOl) { html.push('</ol>'); inOl = false; }
                var level = Math.min(headingMatch[1].length + 2, 6); // h3-h6 range for chat
                html.push('<h' + level + ' class="vc-md-heading">' + headingMatch[2] + '</h' + level + '>');
                continue;
            }

            // Unordered list: - item or * item
            var ulMatch = line.match(/^\s*[-*]\s+(.+)$/);
            if (ulMatch) {
                if (inOl) { html.push('</ol>'); inOl = false; }
                if (!inUl) { html.push('<ul class="vc-md-list">'); inUl = true; }
                html.push('<li>' + ulMatch[1] + '</li>');
                continue;
            }

            // Ordered list: 1. item
            var olMatch = line.match(/^\s*\d+\.\s+(.+)$/);
            if (olMatch) {
                if (inUl) { html.push('</ul>'); inUl = false; }
                if (!inOl) { html.push('<ol class="vc-md-list">'); inOl = true; }
                html.push('<li>' + olMatch[1] + '</li>');
                continue;
            }

            // Close open lists on non-list lines.
            if (inUl) { html.push('</ul>'); inUl = false; }
            if (inOl) { html.push('</ol>'); inOl = false; }

            // Empty line → paragraph break.
            if (line.trim() === '') {
                html.push('<br>');
            } else {
                html.push('<p class="vc-md-p">' + line + '</p>');
            }
        }

        if (inUl) html.push('</ul>');
        if (inOl) html.push('</ol>');

        return html.join('');
    }

    var tutorWidgets = document.querySelectorAll('.videoclass-tutor');
    tutorWidgets.forEach(function(widget) {
        var courseid = widget.dataset.courseid;
        var sectionid = widget.dataset.sectionid;
        var toggle = widget.querySelector('.videoclass-tutor-toggle');
        var body = widget.querySelector('.videoclass-tutor-body');
        var messagesEl = widget.querySelector('.videoclass-tutor-messages');
        var inputEl = widget.querySelector('.videoclass-tutor-input');
        var sendBtn = widget.querySelector('.videoclass-tutor-send');
        var labelEl = widget.querySelector('.videoclass-tutor-label');
        var chevronEl = widget.querySelector('.videoclass-tutor-chevron');
        var convListEl = widget.querySelector('.videoclass-tutor-conv-list');
        var newConvBtn = widget.querySelector('.videoclass-tutor-new-conv');
        var logoIcon = widget.querySelector('[data-action="show-logo"]');
        var widgetId = widget.id.replace('videoclass-tutor-', '');
        var logoModal = document.getElementById('videoclass-logo-modal-' + widgetId);

        var currentConversationId = 0;
        var conversationsLoaded = false;
        var sending = false;

        function scrollToBottom() {
            messagesEl.scrollTop = messagesEl.scrollHeight;
        }

        function appendMessage(role, content, msgId, noteid) {
            var div = document.createElement('div');
            div.className = 'videoclass-tutor-msg videoclass-tutor-msg-' + role;
            var contentDiv = document.createElement('div');
            contentDiv.className = 'videoclass-tutor-msg-content';
            if (role === 'assistant') {
                contentDiv.innerHTML = simpleMarkdown(content);
            } else {
                contentDiv.textContent = content;
            }
            div.appendChild(contentDiv);

            if (role === 'assistant' && content) {
                var saveBtn = document.createElement('button');
                saveBtn.type = 'button';
                saveBtn.className = 'videoclass-tutor-save-note';
                if (msgId) saveBtn.dataset.chatid = msgId;
                if (noteid && noteid > 0) {
                    saveBtn.textContent = '\u2705 Saved!';
                    saveBtn.classList.add('videoclass-tutor-save-done');
                    saveBtn.disabled = true;
                    saveBtn.dataset.noteid = noteid;
                } else {
                    saveBtn.textContent = '\uD83D\uDCDD Save to Notes';
                    saveBtn.addEventListener('click', function() {
                        saveToNotes(content, saveBtn);
                    });
                }
                div.appendChild(saveBtn);
            }

            messagesEl.appendChild(div);
            scrollToBottom();
            return div;
        }

        function saveToNotes(content, btn) {
            btn.disabled = true;
            btn.textContent = 'Saving...';
            var chatid = btn.dataset.chatid ? parseInt(btn.dataset.chatid) : 0;
            require(['core/ajax'], function(Ajax) {
                Ajax.call([{
                    methodname: 'format_videoclass_save_personal_note',
                    args: { courseid: parseInt(courseid), sectionid: parseInt(sectionid), content: content }
                }])[0].then(function(result) {
                    btn.textContent = '\u2705 Saved!';
                    btn.classList.add('videoclass-tutor-save-done');
                    btn.dataset.noteid = result.id;
                    document.dispatchEvent(new CustomEvent('vc-note-saved', { detail: result }));
                    if (chatid > 0) {
                        Ajax.call([{
                            methodname: 'format_videoclass_link_chat_note',
                            args: { chatid: chatid, noteid: result.id }
                        }]);
                    }
                }).catch(function(err) {
                    console.error('[VC Tutor] Save error:', err);
                    btn.textContent = '\uD83D\uDCDD Save to Notes';
                    btn.disabled = false;
                });
            });
        }

        // Re-enable Save button when a note is deleted from My Notes.
        document.addEventListener('vc-note-deleted', function(e) {
            var deletedId = String(e.detail && e.detail.noteid);
            if (!deletedId) return;
            widget.querySelectorAll('.videoclass-tutor-save-note').forEach(function(btn) {
                if (btn.dataset.noteid === deletedId) {
                    btn.textContent = '\uD83D\uDCDD Save to Notes';
                    btn.classList.remove('videoclass-tutor-save-done');
                    btn.disabled = false;
                    delete btn.dataset.noteid;
                    var chatid = btn.dataset.chatid ? parseInt(btn.dataset.chatid) : 0;
                    if (chatid > 0) {
                        require(['core/ajax'], function(Ajax) {
                            Ajax.call([{
                                methodname: 'format_videoclass_link_chat_note',
                                args: { chatid: chatid, noteid: 0 }
                            }]);
                        });
                    }
                    var msgContent = btn.closest('.videoclass-tutor-msg').querySelector('.videoclass-tutor-msg-content');
                    var noteContent = msgContent ? msgContent.textContent : '';
                    btn.addEventListener('click', function() {
                        saveToNotes(noteContent, btn);
                    });
                }
            });
        });

        // ── Conversation Sidebar ──
        var sharedListEl = widget.querySelector('.videoclass-tutor-shared-list');
        var sharePickerEl = widget.querySelector('.videoclass-tutor-share-picker');
        var readonlyNotice = widget.querySelector('.videoclass-tutor-readonly-notice');
        var inputRowEl = widget.querySelector('.videoclass-tutor-input-row');
        var isReadOnly = false;
        var shareConvId = 0;
        var shareRecipients = [];

        function setReadOnly(readonly) {
            isReadOnly = readonly;
            if (readonly) {
                inputRowEl.style.display = 'none';
                readonlyNotice.style.display = 'block';
            } else {
                inputRowEl.style.display = '';
                readonlyNotice.style.display = 'none';
            }
        }

        function loadConversations(selectId) {
            require(['core/ajax'], function(Ajax) {
                Ajax.call([{
                    methodname: 'format_videoclass_get_chat_conversations',
                    args: { courseid: parseInt(courseid), sectionid: parseInt(sectionid) }
                }])[0].then(function(result) {
                    var convs = result;
                    if (result && result.data) convs = result.data;
                    renderConversationList(convs || [], selectId);
                    conversationsLoaded = true;
                }).catch(function(err) {
                    console.error('[VC Tutor] Load conversations error:', err);
                });
            });
            loadSharedConversations();
        }

        function renderConversationList(convs, selectId) {
            convListEl.innerHTML = '';
            if (!convs || convs.length === 0) {
                convListEl.innerHTML = '<div class="videoclass-tutor-conv-empty">No conversations yet.</div>';
                return;
            }
            convs.forEach(function(c) {
                var item = document.createElement('div');
                item.className = 'videoclass-tutor-conv-item';
                if (c.id === selectId || c.id === currentConversationId) {
                    item.classList.add('active');
                }
                item.dataset.convid = c.id;

                var info = document.createElement('div');
                info.style.flex = '1';
                info.style.minWidth = '0';

                var title = document.createElement('div');
                title.className = 'videoclass-tutor-conv-title';
                title.textContent = c.title;
                title.title = 'Double-click to rename';
                info.appendChild(title);

                // Shared badge.
                if (c.shared) {
                    var badge = document.createElement('span');
                    badge.className = 'videoclass-tutor-conv-shared-badge';
                    badge.textContent = 'Shared';
                    info.appendChild(badge);
                }

                var time = document.createElement('div');
                time.className = 'videoclass-tutor-conv-time';
                var d = new Date(c.timemodified * 1000);
                time.textContent = d.toLocaleDateString() + ' ' + d.toLocaleTimeString([], {hour: '2-digit', minute:'2-digit'});
                info.appendChild(time);

                // Actions row.
                var actions = document.createElement('div');
                actions.className = 'videoclass-tutor-conv-actions';

                // Share / Unshare button.
                var shareBtn = document.createElement('button');
                shareBtn.type = 'button';
                if (c.shared) {
                    shareBtn.className = 'videoclass-tutor-conv-action-btn videoclass-tutor-conv-unshare';
                    shareBtn.innerHTML = '&#x1F512;';
                    shareBtn.title = 'Unshare conversation';
                    shareBtn.addEventListener('click', function(e) {
                        e.stopPropagation();
                        unshareConversation(c.id);
                    });
                } else {
                    shareBtn.className = 'videoclass-tutor-conv-action-btn videoclass-tutor-conv-share';
                    shareBtn.innerHTML = '&#x1F4E4;';
                    shareBtn.title = 'Share conversation';
                    shareBtn.addEventListener('click', function(e) {
                        e.stopPropagation();
                        openSharePicker(c.id);
                    });
                }
                actions.appendChild(shareBtn);

                var delBtn = document.createElement('button');
                delBtn.type = 'button';
                delBtn.className = 'videoclass-tutor-conv-action-btn videoclass-tutor-conv-delete';
                delBtn.innerHTML = '&#x1F5D1;';
                delBtn.title = 'Delete conversation';
                delBtn.addEventListener('click', function(e) {
                    e.stopPropagation();
                    if (!confirm('Delete this conversation? All messages will be lost.')) return;
                    deleteConversation(c.id);
                });
                actions.appendChild(delBtn);

                item.appendChild(info);
                item.appendChild(actions);

                // Double-click to rename.
                title.addEventListener('dblclick', function(e) {
                    e.stopPropagation();
                    startInlineRename(title, c.id, c.title);
                });

                item.addEventListener('click', function() {
                    setReadOnly(false);
                    switchConversation(c.id);
                });

                convListEl.appendChild(item);
            });
        }

        // ── Inline Rename ──
        function startInlineRename(titleEl, convId, currentTitle) {
            var input = document.createElement('input');
            input.type = 'text';
            input.className = 'videoclass-tutor-conv-rename-input';
            input.value = currentTitle;
            titleEl.textContent = '';
            titleEl.appendChild(input);
            input.focus();
            input.select();

            function finishRename() {
                var newTitle = input.value.trim();
                if (newTitle && newTitle !== currentTitle) {
                    renameConversation(convId, newTitle);
                    titleEl.textContent = newTitle;
                    titleEl.title = 'Double-click to rename';
                } else {
                    titleEl.textContent = currentTitle;
                    titleEl.title = 'Double-click to rename';
                }
            }

            input.addEventListener('keydown', function(e) {
                if (e.key === 'Enter') { e.preventDefault(); input.blur(); }
                if (e.key === 'Escape') { input.value = currentTitle; input.blur(); }
            });
            input.addEventListener('blur', finishRename);
            input.addEventListener('click', function(e) { e.stopPropagation(); });
        }

        function renameConversation(convId, newTitle) {
            require(['core/ajax'], function(Ajax) {
                Ajax.call([{
                    methodname: 'format_videoclass_rename_chat_conversation',
                    args: { conversationid: convId, title: newTitle }
                }])[0].catch(function(err) {
                    console.error('[VC Tutor] Rename error:', err);
                });
            });
        }

        // ── Share Picker ──
        function openSharePicker(convId) {
            shareConvId = convId;
            shareRecipients = [];
            sharePickerEl.style.display = 'block';
            var searchInput = sharePickerEl.querySelector('.videoclass-tutor-share-search');
            var resultsEl = sharePickerEl.querySelector('.videoclass-tutor-share-results');
            var chipsEl = sharePickerEl.querySelector('.videoclass-tutor-share-chips');
            var confirmBtn = sharePickerEl.querySelector('.videoclass-tutor-share-confirm');
            searchInput.value = '';
            resultsEl.innerHTML = '';
            chipsEl.innerHTML = '';
            confirmBtn.disabled = true;
            searchInput.focus();

            var searchTimer = null;
            searchInput.oninput = function() {
                clearTimeout(searchTimer);
                var q = searchInput.value.trim();
                if (q.length < 2) { resultsEl.innerHTML = ''; return; }
                searchTimer = setTimeout(function() {
                    require(['core/ajax'], function(Ajax) {
                        Ajax.call([{
                            methodname: 'format_videoclass_search_students',
                            args: { courseid: parseInt(courseid), query: q }
                        }])[0].then(function(users) {
                            var data = users;
                            if (users && users.data) data = users.data;
                            resultsEl.innerHTML = '';
                            (data || []).forEach(function(u) {
                                if (shareRecipients.indexOf(u.id) !== -1) return;
                                var opt = document.createElement('div');
                                opt.className = 'videoclass-tutor-share-result';
                                opt.textContent = u.fullname;
                                opt.addEventListener('click', function() {
                                    shareRecipients.push(u.id);
                                    addChip(u.id, u.fullname, chipsEl, confirmBtn);
                                    resultsEl.innerHTML = '';
                                    searchInput.value = '';
                                    searchInput.focus();
                                });
                                resultsEl.appendChild(opt);
                            });
                        });
                    });
                }, 300);
            };

            confirmBtn.onclick = function() {
                if (shareRecipients.length === 0) return;
                shareConversation(shareConvId, shareRecipients);
                closeSharePicker();
            };
        }

        function addChip(uid, name, chipsEl, confirmBtn) {
            var chip = document.createElement('span');
            chip.className = 'videoclass-tutor-share-chip';
            chip.textContent = name;
            var rm = document.createElement('button');
            rm.type = 'button';
            rm.className = 'videoclass-tutor-share-chip-remove';
            rm.innerHTML = '&times;';
            rm.addEventListener('click', function() {
                shareRecipients = shareRecipients.filter(function(id) { return id !== uid; });
                chip.remove();
                confirmBtn.disabled = shareRecipients.length === 0;
            });
            chip.appendChild(rm);
            chipsEl.appendChild(chip);
            confirmBtn.disabled = false;
        }

        function closeSharePicker() {
            sharePickerEl.style.display = 'none';
            shareConvId = 0;
            shareRecipients = [];
        }

        // Close button.
        sharePickerEl.querySelector('.videoclass-tutor-share-picker-close').addEventListener('click', closeSharePicker);

        function shareConversation(convId, recipients) {
            require(['core/ajax'], function(Ajax) {
                Ajax.call([{
                    methodname: 'format_videoclass_share_chat_conversation',
                    args: { conversationid: convId, recipients: recipients }
                }])[0].then(function() {
