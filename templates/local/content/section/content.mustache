        function renderSharedConversationList(convs) {
            if (!sharedListEl) return;
            sharedListEl.innerHTML = '';
            if (!convs || convs.length === 0) {
                sharedListEl.innerHTML = '<div class="videoclass-tutor-conv-empty">No shared conversations.</div>';
                return;
            }
            convs.forEach(function(c) {
                var item = document.createElement('div');
                item.className = 'videoclass-tutor-conv-item videoclass-tutor-conv-shared';
                item.dataset.convid = c.id;

                var info = document.createElement('div');
                info.style.flex = '1';
                info.style.minWidth = '0';

                var title = document.createElement('div');
                title.className = 'videoclass-tutor-conv-title';
                title.textContent = c.title;
                title.title = c.title;
                info.appendChild(title);

                var owner = document.createElement('div');
                owner.className = 'videoclass-tutor-conv-owner';
                owner.textContent = 'by ' + c.ownername;
                info.appendChild(owner);

                item.appendChild(info);

                item.addEventListener('click', function() {
                    switchToSharedConversation(c.id);
                });

                sharedListEl.appendChild(item);
            });
