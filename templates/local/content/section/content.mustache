                }).catch(function(err) {
                    console.error('[VC Tutor] Share error:', err);
                });
            });
        }

        function unshareConversation(convId) {
            require(['core/ajax'], function(Ajax) {
                Ajax.call([{
                    methodname: 'format_videoclass_unshare_chat_conversation',
                    args: { conversationid: convId }
                }])[0].then(function() {
                    loadConversations(currentConversationId);
                }).catch(function(err) {
                    console.error('[VC Tutor] Unshare error:', err);
                });
            });
        }

        // ── Shared Conversations ──
        function loadSharedConversations() {
            require(['core/ajax'], function(Ajax) {
                Ajax.call([{
                    methodname: 'format_videoclass_get_shared_conversations',
                    args: { courseid: parseInt(courseid), sectionid: parseInt(sectionid) }
                }])[0].then(function(result) {
                    var convs = result;
                    if (result && result.data) convs = result.data;
                    renderSharedConversationList(convs || []);
                }).catch(function(err) {
                    console.error('[VC Tutor] Load shared conversations error:', err);
                });
            });
