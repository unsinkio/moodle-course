{{!
    @template format_videoclass/local/content/section/content
}}
<div class="videoclass-section-content">
    {{#availability}}
        <div class="videoclass-availability">{{{availability}}}</div>
    {{/availability}}

    {{! ── Section layout: sidebar left, video right ── }}
    <div class="videoclass-layout" data-section-id="{{id}}">
        {{! ── Sidebar: section navigation ── }}
        <aside class="videoclass-sidebar">
            <div class="videoclass-sidebar-header">{{#str}}tabresources, format_videoclass{{/str}}</div>
            <nav class="videoclass-sections-nav" aria-label="Course sections">
                {{#videoclass.sectionsnav}}
                    <a class="videoclass-section-link {{#current}}is-current{{/current}}" href="{{url}}">
                        {{name}}
                    </a>
                {{/videoclass.sectionsnav}}
                {{^videoclass.sectionsnav}}
                    <div class="videoclass-empty">{{#str}}noresources, format_videoclass{{/str}}</div>
                {{/videoclass.sectionsnav}}
            </nav>
        </aside>

        {{! ── Video column ── }}
        <div class="videoclass-video" id="videoclass-video-{{id}}">
            {{#editing}}
                <div class="videoclass-edit-row">
                    <a class="videoclass-edit-button" href="{{videoclass.editurl}}">{{#str}}editsection, format_videoclass{{/str}}</a>
                </div>
            {{/editing}}
            {{#videoclass.hasvideo}}
                <div class="videoclass-video-embed">
                    {{{summary.summarytext}}}
                </div>
            {{/videoclass.hasvideo}}
            {{^videoclass.hasvideo}}
                <div class="videoclass-video-empty">
                    <span>{{#str}}videoplaceholder, format_videoclass{{/str}}</span>
                </div>
            {{/videoclass.hasvideo}}
        </div>
    </div>

    {{! ── AI Tutor (collapsible) ── }}
    <div class="videoclass-tutor" id="videoclass-tutor-{{id}}"
         data-courseid="{{videoclass.courseid}}"
         data-sectionid="{{videoclass.sectionid}}"
         data-sesskey="{{videoclass.sesskey}}"
         data-logourl="{{videoclass.logourl}}">
        <button type="button" class="videoclass-tutor-toggle" aria-expanded="false"
                aria-controls="videoclass-tutor-body-{{id}}">
            <span class="videoclass-tutor-icon" data-action="show-logo">{{#pix}}atlas_icon, format_videoclass, ATLAS{{/pix}}</span>
            <span class="videoclass-tutor-label">{{#str}}aitutorexpand, format_videoclass{{/str}}</span>
            <span class="videoclass-tutor-chevron">&#x25BC;</span>
        </button>
        <div class="videoclass-tutor-body" id="videoclass-tutor-body-{{id}}" hidden>
            <div class="videoclass-tutor-layout">
                {{! ── Conversation Sidebar ── }}
                <div class="videoclass-tutor-sidebar" id="videoclass-tutor-sidebar-{{id}}">
                    <div class="videoclass-tutor-sidebar-header">
                        <span>{{#str}}aitutorconversations, format_videoclass{{/str}}</span>
                        <button type="button" class="videoclass-tutor-new-conv"
                                id="videoclass-tutor-new-conv-{{id}}"
                                title="{{#str}}aitutornewconversation, format_videoclass{{/str}}">&#x2B; New</button>
                    </div>
                    <div class="videoclass-tutor-conv-list" id="videoclass-tutor-conv-list-{{id}}">
                        <div class="videoclass-tutor-conv-empty">{{#str}}aitutornoconversations, format_videoclass{{/str}}</div>
                    </div>
                    {{! ── Shared With Me ── }}
                    <div class="videoclass-tutor-shared-section" id="videoclass-tutor-shared-section-{{id}}">
                        <div class="videoclass-tutor-sidebar-subheader">{{#str}}aitutorsharedchats, format_videoclass{{/str}}</div>
                        <div class="videoclass-tutor-shared-list" id="videoclass-tutor-shared-list-{{id}}">
                            <div class="videoclass-tutor-conv-empty">{{#str}}aitutornosharedchats, format_videoclass{{/str}}</div>
                        </div>
                    </div>
                </div>
                {{! ── Sidebar Backdrop (mobile only) ── }}
                <div class="videoclass-tutor-sidebar-backdrop"></div>
                {{! ── Chat Column ── }}
                <div class="videoclass-tutor-chat-col">
                    <div class="videoclass-tutor-chat-header">
                        <button type="button" class="videoclass-tutor-sidebar-toggle"
                                title="{{#str}}aitutorconversations, format_videoclass{{/str}}">&#x2630;</button>
                        <button type="button" class="videoclass-tutor-new-conv-mobile"
                                title="{{#str}}aitutornewconversation, format_videoclass{{/str}}">&#x2B; New</button>
                    </div>
                    {{! ── Share Picker Overlay ── }}
                    <div class="videoclass-tutor-share-picker" id="videoclass-tutor-share-picker-{{id}}" style="display:none;">
                        <div class="videoclass-tutor-share-picker-header">
                            <span>{{#str}}aitutorshare, format_videoclass{{/str}}</span>
                            <button type="button" class="videoclass-tutor-share-picker-close">&times;</button>
                        </div>
                        <input type="text" class="videoclass-tutor-share-search"
                               placeholder="Search students..." autocomplete="off">
                        <div class="videoclass-tutor-share-results"></div>
                        <div class="videoclass-tutor-share-chips"></div>
                        <button type="button" class="videoclass-tutor-share-confirm"
                                disabled>Share</button>
                    </div>
                    {{! ── Read-Only Notice ── }}
                    <div class="videoclass-tutor-readonly-notice" id="videoclass-tutor-readonly-{{id}}" style="display:none;">
                        {{#str}}aitutorreadonlychat, format_videoclass{{/str}}
                    </div>
                    <div class="videoclass-tutor-messages" id="videoclass-tutor-messages-{{id}}">
                        <div class="videoclass-tutor-msg videoclass-tutor-msg-assistant">
                            <div class="videoclass-tutor-msg-content">{{#str}}aitutorwelcome, format_videoclass{{/str}}</div>
                        </div>
                    </div>
                    <div class="videoclass-tutor-input-row">
                        <textarea class="videoclass-tutor-input"
                                  id="videoclass-tutor-input-{{id}}"
                                  placeholder="{{#str}}aitutorplaceholder, format_videoclass{{/str}}"
                                  rows="1"
                                  autocomplete="off"></textarea>
                        <button type="button" class="videoclass-tutor-send"
                                id="videoclass-tutor-send-{{id}}">{{#str}}aitutorsend, format_videoclass{{/str}}</button>
                    </div>
                </div>
            </div>
        </div>
    </div>

    {{! ── Logo Lightbox Modal ── }}
    <div class="videoclass-logo-modal" id="videoclass-logo-modal-{{id}}" style="display:none;">
        <div class="videoclass-logo-modal-backdrop"></div>
        <div class="videoclass-logo-modal-content">
            <button type="button" class="videoclass-logo-modal-close">&times;</button>
            <img src="{{videoclass.logourl}}" alt="{{#str}}aitutorlogoalt, format_videoclass{{/str}}" class="videoclass-logo-modal-img">
        </div>
    </div>

    {{! ── Tabs below layout ── }}
    <div class="videoclass-tabs" role="tablist">
            <input type="radio" name="videoclass-tabs-{{id}}" id="videoclass-tab-{{id}}-resources"
                   class="videoclass-tab-radio" checked aria-controls="videoclass-panel-{{id}}-resources">
            <label for="videoclass-tab-{{id}}-resources" class="videoclass-tab-label" role="tab">
                {{#str}}tabresources, format_videoclass{{/str}}
            </label>

            <input type="radio" name="videoclass-tabs-{{id}}" id="videoclass-tab-{{id}}-assessments"
                   class="videoclass-tab-radio" aria-controls="videoclass-panel-{{id}}-assessments">
            <label for="videoclass-tab-{{id}}-assessments" class="videoclass-tab-label" role="tab">
                {{#str}}tabassessments, format_videoclass{{/str}}
            </label>

            <input type="radio" name="videoclass-tabs-{{id}}" id="videoclass-tab-{{id}}-qa"
                   class="videoclass-tab-radio" aria-controls="videoclass-panel-{{id}}-qa">
            <label for="videoclass-tab-{{id}}-qa" class="videoclass-tab-label" role="tab">
                {{#str}}tabqa, format_videoclass{{/str}}
            </label>

            <input type="radio" name="videoclass-tabs-{{id}}" id="videoclass-tab-{{id}}-mynotes"
                   class="videoclass-tab-radio" aria-controls="videoclass-panel-{{id}}-mynotes">
            <label for="videoclass-tab-{{id}}-mynotes" class="videoclass-tab-label" role="tab">
                {{#str}}tabmynotes, format_videoclass{{/str}}
            </label>

            <input type="radio" name="videoclass-tabs-{{id}}" id="videoclass-tab-{{id}}-sharednotes"
                   class="videoclass-tab-radio" aria-controls="videoclass-panel-{{id}}-sharednotes">
            <label for="videoclass-tab-{{id}}-sharednotes" class="videoclass-tab-label" role="tab">
                {{#str}}tabsharednotes, format_videoclass{{/str}}
            </label>

            {{! Tab panels }}
            <div class="videoclass-tab-panels">
                {{! ── Tab 1: Resources ── }}
                <section class="videoclass-tab-panel" role="tabpanel" aria-labelledby="videoclass-tab-{{id}}-resources">
                    {{#videoclass.resources}}
                        <div class="videoclass-activity" data-activity-id="{{id}}">
                            <div class="videoclass-activity-icon">{{{icon}}}</div>
                            <a href="{{url}}" class="videoclass-activity-link">{{name}}</a>
                            {{#editing}}
                                <div class="videoclass-edit-row">{{{cmcontrols}}}</div>
                            {{/editing}}
                        </div>
                    {{/videoclass.resources}}
                    {{^videoclass.resources}}
                        <div class="videoclass-empty">{{#str}}noresources, format_videoclass{{/str}}</div>
                    {{/videoclass.resources}}
                </section>

                {{! ── Tab 2: Assessments ── }}
                <section class="videoclass-tab-panel" role="tabpanel" aria-labelledby="videoclass-tab-{{id}}-assessments">
                    {{#videoclass.assessments}}
                        <div class="videoclass-activity" data-activity-id="{{id}}">
                            <div class="videoclass-activity-icon">{{{icon}}}</div>
                            <a href="{{url}}" class="videoclass-activity-link">{{name}}</a>
                            {{#editing}}
                                <div class="videoclass-edit-row">{{{cmcontrols}}}</div>
                            {{/editing}}
                        </div>
                    {{/videoclass.assessments}}
                    {{^videoclass.assessments}}
                        <div class="videoclass-empty">{{#str}}noassessments, format_videoclass{{/str}}</div>
                    {{/videoclass.assessments}}
                </section>

                {{! ── Tab 3: Q&A ── }}
                <section class="videoclass-tab-panel" role="tabpanel" aria-labelledby="videoclass-tab-{{id}}-qa">
                    {{#videoclass.qa}}
                        <div class="videoclass-activity" data-activity-id="{{id}}">
                            <div class="videoclass-activity-icon">{{{icon}}}</div>
                            <a href="{{url}}" class="videoclass-activity-link">{{name}}</a>
                            {{#editing}}
                                <div class="videoclass-edit-row">{{{cmcontrols}}}</div>
                            {{/editing}}
                        </div>
                    {{/videoclass.qa}}
                    {{^videoclass.qa}}
                        <div class="videoclass-empty">{{#str}}noqaprefix, format_videoclass{{/str}}</div>
                    {{/videoclass.qa}}
                </section>

                {{! ── Tab 4: My Notes ── }}
                <section class="videoclass-tab-panel" role="tabpanel" aria-labelledby="videoclass-tab-{{id}}-mynotes">
                    <div class="videoclass-mynotes" id="videoclass-mynotes-{{id}}"
                         data-courseid="{{videoclass.courseid}}"
                         data-sectionid="{{videoclass.sectionid}}"
                         data-sesskey="{{videoclass.sesskey}}">
                        {{! Write new note }}
                        <div class="videoclass-mynotes-form">
                            <textarea class="videoclass-mynotes-input"
                                      id="videoclass-mynotes-input-{{id}}"
                                      placeholder="{{#str}}mynoteplaceholder, format_videoclass{{/str}}"
                                      rows="3"></textarea>
                            <button type="button" class="videoclass-mynotes-submit"
                                    id="videoclass-mynotes-submit-{{id}}">
                                {{#str}}savenote, format_videoclass{{/str}}
                            </button>
                        </div>
                        {{! Saved notes list }}
                        <div class="videoclass-mynotes-list" id="videoclass-mynotes-list-{{id}}">
                            {{#videoclass.personalnotes}}
                                <div class="videoclass-mynote-card" data-noteid="{{id}}">
                                    <div class="videoclass-mynote-header">
                                        <span class="videoclass-mynote-time">{{timemodified}}</span>
                                        {{#isshared}}
                                            <span class="videoclass-mynote-badge-shared"
                                                  title="{{recipientnames}}">{{#str}}sharedbadge, format_videoclass{{/str}}</span>
                                        {{/isshared}}
                                        <div class="videoclass-mynote-actions">
                                            {{^isshared}}
                                                <button type="button" class="videoclass-mynote-share"
                                                        data-noteid="{{id}}" title="{{#str}}sharethistnote, format_videoclass{{/str}}">
                                                    &#x1f4e4;
                                                </button>
                                            {{/isshared}}
                                            {{#isshared}}
                                                <button type="button" class="videoclass-mynote-unshare"
                                                        data-noteid="{{id}}" title="{{#str}}unsharenote, format_videoclass{{/str}}">
                                                    &#x1f512;
                                                </button>
                                            {{/isshared}}
                                            <button type="button" class="videoclass-mynote-delete"
                                                    data-noteid="{{id}}" title="{{#str}}deletemynote, format_videoclass{{/str}}">
                                                &times;
                                            </button>
                                        </div>
                                    </div>
                                    {{#isshared}}
                                        <div class="videoclass-mynote-shared-info">&#x1f465; {{recipientnames}}</div>
                                    {{/isshared}}
                                    <div class="videoclass-mynote-content">{{content}}</div>
                                    {{! Inline recipient picker (hidden by default) }}
                                    <div class="videoclass-share-picker" id="videoclass-share-picker-{{id}}" style="display:none;">
                                        <div class="videoclass-share-picker-label">{{#str}}sharenoteprompt, format_videoclass{{/str}}</div>
                                        <input type="text" class="videoclass-recipient-search"
                                               placeholder="{{#str}}searchstudents, format_videoclass{{/str}}"
                                               autocomplete="off">
                                        <div class="videoclass-recipient-results"></div>
                                        <div class="videoclass-recipient-chips"></div>
                                        <button type="button" class="videoclass-share-confirm">{{#str}}sharethistnote, format_videoclass{{/str}}</button>
                                    </div>
                                </div>
                            {{/videoclass.personalnotes}}
                            {{^videoclass.personalnotes}}
                                <div class="videoclass-empty videoclass-mynotes-empty">{{#str}}nomynotes, format_videoclass{{/str}}</div>
                            {{/videoclass.personalnotes}}
                        </div>
                    </div>
                </section>

                {{! ── Tab 5: Shared Notes (Shared with me) ── }}
                <section class="videoclass-tab-panel" role="tabpanel" aria-labelledby="videoclass-tab-{{id}}-sharednotes">
                    <div class="videoclass-sharedwithme" id="videoclass-sharedwithme-{{id}}"
                         data-courseid="{{videoclass.courseid}}"
                         data-sectionid="{{videoclass.sectionid}}">
                        <div class="videoclass-sharedwithme-list" id="videoclass-sharedwithme-list-{{id}}">
                            {{#videoclass.sharedwithme}}
                                <div class="videoclass-sharedwithme-card" data-noteid="{{id}}">
                                    <div class="videoclass-sharedwithme-header">
                                        <span class="videoclass-sharedwithme-author">{{authorfullname}}</span>
                                        <span class="videoclass-sharedwithme-time">{{timeshared}}</span>
                                    </div>
                                    <div class="videoclass-sharedwithme-content">{{content}}</div>
                                </div>
                            {{/videoclass.sharedwithme}}
                            {{^videoclass.sharedwithme}}
                                <div class="videoclass-empty videoclass-sharedwithme-empty">{{#str}}nosharednotes, format_videoclass{{/str}}</div>
                            {{/videoclass.sharedwithme}}
                        </div>
                    </div>
                </section>
            </div>
        </div>
    </div>

    {{{cmcontrols}}}
</div>
{{#js}}
(function() {
    var myContainers = document.querySelectorAll('.videoclass-mynotes');
    myContainers.forEach(function(container) {
        var courseid = container.dataset.courseid;
        var sectionid = container.dataset.sectionid;
        var sesskey = container.dataset.sesskey;
        var cid = container.id.replace('videoclass-mynotes-', '');
        var input = document.getElementById('videoclass-mynotes-input-' + cid);
        var submitBtn = document.getElementById('videoclass-mynotes-submit-' + cid);
        var listEl = document.getElementById('videoclass-mynotes-list-' + cid);

        if (!submitBtn || !input || !listEl) return;

        // Listen for notes saved from AI Tutor chat.
        document.addEventListener('vc-note-saved', function(e) {
            var note = e.detail;
            if (note && note.id) {
                var emptyMsg = listEl.querySelector('.videoclass-mynotes-empty');
                if (emptyMsg) emptyMsg.remove();
                listEl.prepend(buildCard(note));
            }
        });

        function ajaxCall(method, args) {
            return fetch(M.cfg.wwwroot + '/lib/ajax/service.php?sesskey=' + sesskey, {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify([{ methodname: method, args: args }])
            }).then(function(r) { return r.json(); });
        }

        function buildCard(note) {
            var card = document.createElement('div');
            card.className = 'videoclass-mynote-card';
            card.dataset.noteid = note.id;
            card.innerHTML =
                '<div class="videoclass-mynote-header">' +
                    '<span class="videoclass-mynote-time">' + note.timemodified + '</span>' +
                    '<div class="videoclass-mynote-actions">' +
                        '<button type="button" class="videoclass-mynote-share" data-noteid="' + note.id + '" title="Share">&#x1f4e4;</button>' +
                        '<button type="button" class="videoclass-mynote-delete" data-noteid="' + note.id + '" title="Delete">&times;</button>' +
                    '</div>' +
                '</div>' +
                '<div class="videoclass-mynote-content">' + note.content + '</div>' +
                '<div class="videoclass-share-picker" style="display:none;">' +
                    '<div class="videoclass-share-picker-label">Select classmates to share this note with:</div>' +
                    '<input type="text" class="videoclass-recipient-search" placeholder="Search classmates..." autocomplete="off">' +
                    '<div class="videoclass-recipient-results"></div>' +
                    '<div class="videoclass-recipient-chips"></div>' +
                    '<button type="button" class="videoclass-share-confirm">Share</button>' +
                '</div>';
            return card;
        }

        submitBtn.addEventListener('click', function() {
            var content = input.value.trim();
            if (!content) return;
            submitBtn.disabled = true;
            ajaxCall('format_videoclass_save_personal_note', {
                courseid: parseInt(courseid),
                sectionid: parseInt(sectionid),
                content: content
            }).then(function(results) {
                var res = results[0];
                if (res && !res.error) {
                    var emptyMsg = listEl.querySelector('.videoclass-mynotes-empty');
                    if (emptyMsg) emptyMsg.remove();
                    listEl.prepend(buildCard(res));
                    input.value = '';
                } else {
                    alert(res && res.exception ? res.exception.message : 'Error saving note');
                }
                submitBtn.disabled = false;
            }).catch(function(err) { console.error('Save error:', err); submitBtn.disabled = false; });
        });

        listEl.addEventListener('click', function(e) {
            var card = e.target.closest('.videoclass-mynote-card');
            if (!card) return;
            var noteid = card.dataset.noteid;

            if (e.target.closest('.videoclass-mynote-delete')) {
                if (!confirm('Are you sure you want to delete this note?')) return;
                ajaxCall('format_videoclass_delete_personal_note', {
                    noteid: parseInt(noteid)
                }).then(function(results) {
                    if (results[0] && !results[0].error) {
                        card.remove();
                        // Notify AI Tutor to re-enable Save button.
                        document.dispatchEvent(new CustomEvent('vc-note-deleted', { detail: { noteid: noteid } }));
                        if (!listEl.querySelector('.videoclass-mynote-card')) {
                            var empty = document.createElement('div');
                            empty.className = 'videoclass-empty videoclass-mynotes-empty';
                            empty.textContent = 'No notes for this topic yet. Write one above!';
                            listEl.appendChild(empty);
                        }
                    }
                });
                return;
            }

            if (e.target.closest('.videoclass-mynote-unshare')) {
                ajaxCall('format_videoclass_unshare_note', {
                    noteid: parseInt(noteid)
                }).then(function(results) {
                    if (results[0] && !results[0].error) {
                        var badge = card.querySelector('.videoclass-mynote-badge-shared');
                        if (badge) badge.remove();
                        var info = card.querySelector('.videoclass-mynote-shared-info');
                        if (info) info.remove();
                        var unsBtn = card.querySelector('.videoclass-mynote-unshare');
                        if (unsBtn) {
                            var shareBtn = document.createElement('button');
                            shareBtn.type = 'button';
                            shareBtn.className = 'videoclass-mynote-share';
                            shareBtn.dataset.noteid = noteid;
                            shareBtn.title = 'Share';
                            shareBtn.innerHTML = '&#x1f4e4;';
                            unsBtn.replaceWith(shareBtn);
                        }
                    }
                });
                return;
            }

            if (e.target.closest('.videoclass-mynote-share')) {
                var picker = card.querySelector('.videoclass-share-picker');
                if (picker) {
                    picker.style.display = picker.style.display === 'none' ? 'block' : 'none';
                }
                return;
            }

            if (e.target.closest('.videoclass-share-confirm')) {
                var picker = card.querySelector('.videoclass-share-picker');
                var chips = picker.querySelectorAll('.videoclass-recipient-chip');
                var recipientIds = [];
                var recipientNames = [];
                chips.forEach(function(c) {
                    recipientIds.push(parseInt(c.dataset.userid));
                    recipientNames.push(c.dataset.fullname);
                });
                if (recipientIds.length === 0) return;
                ajaxCall('format_videoclass_share_note', {
                    noteid: parseInt(noteid),
                    recipients: recipientIds
                }).then(function(results) {
                    if (results[0] && !results[0].error) {
                        picker.style.display = 'none';
                        var header = card.querySelector('.videoclass-mynote-header');
                        var existingBadge = header.querySelector('.videoclass-mynote-badge-shared');
                        if (!existingBadge) {
                            var badge = document.createElement('span');
                            badge.className = 'videoclass-mynote-badge-shared';
                            badge.title = recipientNames.join(', ');
                            badge.textContent = 'Shared';
                            header.querySelector('.videoclass-mynote-time').after(badge);
                        }
                        var existingInfo = card.querySelector('.videoclass-mynote-shared-info');
                        if (existingInfo) {
                            existingInfo.innerHTML = '&#x1f465; ' + recipientNames.join(', ');
                        } else {
                            var infoDiv = document.createElement('div');
                            infoDiv.className = 'videoclass-mynote-shared-info';
                            infoDiv.innerHTML = '&#x1f465; ' + recipientNames.join(', ');
                            header.after(infoDiv);
                        }
                        var shareBtn = card.querySelector('.videoclass-mynote-share');
                        if (shareBtn) {
                            var unsBtn = document.createElement('button');
                            unsBtn.type = 'button';
                            unsBtn.className = 'videoclass-mynote-unshare';
                            unsBtn.dataset.noteid = noteid;
