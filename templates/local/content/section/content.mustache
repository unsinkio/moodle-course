        function switchToSharedConversation(convId) {
            currentConversationId = convId;
            setReadOnly(true);
            // Deselect own conversations, highlight shared.
            convListEl.querySelectorAll('.videoclass-tutor-conv-item').forEach(function(el) {
                el.classList.remove('active');
            });
            sharedListEl.querySelectorAll('.videoclass-tutor-conv-item').forEach(function(el) {
                el.classList.toggle('active', parseInt(el.dataset.convid) === convId);
            });
            // Load messages (read-only, no save-to-notes buttons).
            messagesEl.innerHTML = '';
            require(['core/ajax'], function(Ajax) {
                Ajax.call([{
                    methodname: 'format_videoclass_get_chat_history',
                    args: { courseid: parseInt(courseid), sectionid: parseInt(sectionid), conversationid: convId }
                }])[0].then(function(result) {
                    var msgs = result;
                    if (result && result.data) msgs = result.data;
                    messagesEl.innerHTML = '';
                    if (msgs && msgs.length > 0) {
                        msgs.forEach(function(m) {
                            // Render without save-to-notes.
                            var msgDiv = document.createElement('div');
                            msgDiv.className = 'videoclass-tutor-msg videoclass-tutor-msg-' + m.role;
                            var content = document.createElement('div');
                            content.className = 'videoclass-tutor-msg-content';
                            if (m.role === 'assistant') {
                                content.innerHTML = simpleMarkdown(m.message);
                            } else {
                                content.textContent = m.message;
                            }
                            msgDiv.appendChild(content);
                            messagesEl.appendChild(msgDiv);
                        });
                    } else {
                        appendMessage('assistant', 'This shared conversation has no messages.');
                    }
                    scrollToBottom();
                }).catch(function(err) {
                    console.error('[VC Tutor] Load shared history error:', err);
                });
            });
            closeSidebarDrawer();
        }

        function switchConversation(convId) {
            currentConversationId = convId;
            setReadOnly(false);
            // Highlight active in own list, deselect shared.
            convListEl.querySelectorAll('.videoclass-tutor-conv-item').forEach(function(el) {
                el.classList.toggle('active', parseInt(el.dataset.convid) === convId);
            });
            if (sharedListEl) {
                sharedListEl.querySelectorAll('.videoclass-tutor-conv-item').forEach(function(el) {
                    el.classList.remove('active');
                });
            }
            // Load messages.
            showWelcome();
            require(['core/ajax'], function(Ajax) {
                Ajax.call([{
                    methodname: 'format_videoclass_get_chat_history',
                    args: { courseid: parseInt(courseid), sectionid: parseInt(sectionid), conversationid: convId }
                }])[0].then(function(result) {
                    var msgs = result;
                    if (result && result.data) msgs = result.data;
                    if (msgs && msgs.length > 0) {
                        messagesEl.innerHTML = '';
                        msgs.forEach(function(m) {
                            appendMessage(m.role, m.message, m.id, m.noteid || 0);
                        });
                    }
                    scrollToBottom();
                }).catch(function(err) {
                    console.error('[VC Tutor] Load history error:', err);
                });
            });
        }

        function deleteConversation(convId) {
            require(['core/ajax'], function(Ajax) {
                Ajax.call([{
                    methodname: 'format_videoclass_delete_chat_conversation',
                    args: { conversationid: convId }
                }])[0].then(function(result) {
                    if (result && (result.success || (result.data && result.data.success))) {
                        if (currentConversationId === convId) {
                            currentConversationId = 0;
                            showWelcome();
                            setReadOnly(false);
                        }
                        loadConversations(currentConversationId);
                    }
                }).catch(function(err) {
                    console.error('[VC Tutor] Delete conversation error:', err);
                });
            });
        }

        function showWelcome() {
            messagesEl.innerHTML = '';
            appendMessage('assistant', 'Hi! I am your AI tutor for this section. Ask me anything about the resources and content here.');
        }

        // New conversation button.
        if (newConvBtn) {
            newConvBtn.addEventListener('click', function() {
                currentConversationId = 0;
                setReadOnly(false);
                showWelcome();
                convListEl.querySelectorAll('.videoclass-tutor-conv-item').forEach(function(el) {
                    el.classList.remove('active');
                });
                if (sharedListEl) sharedListEl.querySelectorAll('.videoclass-tutor-conv-item').forEach(function(el) {
                    el.classList.remove('active');
                });
                inputEl.focus();
            });
        }

        // ── Logo Lightbox ──
        if (logoIcon && logoModal) {
            logoIcon.addEventListener('click', function(e) {
                e.stopPropagation();
                logoModal.style.display = 'block';
            });
            logoModal.querySelector('.videoclass-logo-modal-backdrop').addEventListener('click', function() {
                logoModal.style.display = 'none';
            });
            logoModal.querySelector('.videoclass-logo-modal-close').addEventListener('click', function() {
                logoModal.style.display = 'none';
            });
        }

        // ── Mobile Sidebar Drawer ──
        var sidebarEl = widget.querySelector('.videoclass-tutor-sidebar');
        var sidebarBackdrop = widget.querySelector('.videoclass-tutor-sidebar-backdrop');
        var sidebarToggleBtn = widget.querySelector('.videoclass-tutor-sidebar-toggle');
        var newConvMobileBtn = widget.querySelector('.videoclass-tutor-new-conv-mobile');

        function openSidebarDrawer() {
            if (sidebarEl) sidebarEl.classList.add('open');
            if (sidebarBackdrop) sidebarBackdrop.classList.add('visible');
        }

        function closeSidebarDrawer() {
            if (sidebarEl) sidebarEl.classList.remove('open');
            if (sidebarBackdrop) sidebarBackdrop.classList.remove('visible');
        }

        if (sidebarToggleBtn) {
            sidebarToggleBtn.addEventListener('click', function() {
                if (sidebarEl && sidebarEl.classList.contains('open')) {
                    closeSidebarDrawer();
                } else {
                    if (!conversationsLoaded) loadConversations();
                    openSidebarDrawer();
                }
            });
        }

        if (sidebarBackdrop) {
            sidebarBackdrop.addEventListener('click', closeSidebarDrawer);
        }

        if (newConvMobileBtn) {
            newConvMobileBtn.addEventListener('click', function() {
                currentConversationId = 0;
                showWelcome();
                convListEl.querySelectorAll('.videoclass-tutor-conv-item').forEach(function(el) {
                    el.classList.remove('active');
                });
                closeSidebarDrawer();
                inputEl.focus();
            });
        }

        // Close drawer when a conversation is selected (on mobile).
        var origSwitchConversation = switchConversation;
        switchConversation = function(convId) {
            origSwitchConversation(convId);
            closeSidebarDrawer();
        };

        // Toggle expand/collapse.
        toggle.addEventListener('click', function(e) {
            // Ignore if the logo icon was clicked.
            if (e.target.closest('[data-action="show-logo"]')) return;
            var expanded = toggle.getAttribute('aria-expanded') === 'true';
            if (expanded) {
                body.hidden = true;
                toggle.setAttribute('aria-expanded', 'false');
                labelEl.textContent = 'Show AI Tutor';
                chevronEl.textContent = '\u25BC';
            } else {
                body.hidden = false;
                toggle.setAttribute('aria-expanded', 'true');
                labelEl.textContent = 'Hide tutor';
                chevronEl.textContent = '\u25B2';
                if (!conversationsLoaded) {
                    loadConversations();
                }
                scrollToBottom();
                inputEl.focus();
            }
        });

        function sendMessage() {
            var text = inputEl.value.trim();
            if (!text || sending || isReadOnly) return;
            sending = true;
            inputEl.value = '';
            inputEl.style.height = 'auto';
            sendBtn.disabled = true;

            appendMessage('user', text);

            var typingDiv = document.createElement('div');
            typingDiv.className = 'videoclass-tutor-msg videoclass-tutor-msg-assistant videoclass-tutor-typing';
            typingDiv.innerHTML = '<div class="videoclass-tutor-msg-content"><span class="videoclass-tutor-dots"><span>.</span><span>.</span><span>.</span></span> Thinking...</div>';
            messagesEl.appendChild(typingDiv);
            scrollToBottom();

            require(['core/ajax'], function(Ajax) {
                Ajax.call([{
                    methodname: 'format_videoclass_send_chat_message',
                    args: {
                        courseid: parseInt(courseid),
                        sectionid: parseInt(sectionid),
                        message: text,
                        conversationid: currentConversationId
                    }
                }])[0].then(function(result) {
                    if (typingDiv.parentNode) typingDiv.parentNode.removeChild(typingDiv);
                    var reply = result.reply || (result.data && result.data.reply) || '';
                    if (result.error && !reply) {
                        reply = result.error;
                    }
                    // Track the conversation ID returned by the server.
                    var newConvId = result.conversationid || (result.data && result.data.conversationid) || 0;
                    if (newConvId && newConvId !== currentConversationId) {
                        currentConversationId = newConvId;
                        // Refresh sidebar to include the new conversation.
                        loadConversations(currentConversationId);
                    }
                    appendMessage('assistant', reply, result.msgid || 0);
                    sending = false;
                    sendBtn.disabled = false;
                    inputEl.focus();
                }).catch(function(err) {
                    if (typingDiv.parentNode) typingDiv.parentNode.removeChild(typingDiv);
                    console.error('[VC Tutor] Send error:', err);
                    appendMessage('assistant', 'Sorry, something went wrong. Please try again.');
                    sending = false;
                    sendBtn.disabled = false;
                });
            });
        }

        sendBtn.addEventListener('click', sendMessage);
        inputEl.addEventListener('keydown', function(e) {
            if (e.key === 'Enter' && !e.shiftKey) {
                e.preventDefault();
                sendMessage();
            }
        });

        inputEl.addEventListener('input', function() {
            this.style.height = 'auto';
            this.style.height = Math.min(this.scrollHeight, 120) + 'px';
        });
    });
})();
{{/js}}
